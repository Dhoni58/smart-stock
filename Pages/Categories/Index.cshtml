@page
@model WarehouseSystem.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "Kategorie";
}

<h2>Kategorie</h2>

<a href="/Categories/Create" class="btn btn-primary mb-3">+ Přidat kategorii</a>

<table class="table">
    <thead>
        <tr>
            <th>Název</th>
            <th>Popis</th>
            <th>Počet produktů</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var category in Model.Categories)
        {
            <tr>
                <td>@category.Name</td>
                <td>@category.Description</td>
                <td>@category.Products.Count ks</td>
                <td>
                    <a href="/Categories/Edit/@category.Id" class="btn btn-sm btn-warning">Upravit</a>
                    @if (category.Products.Any())
                    {
                    <button type="button" class="btn btn-sm btn-danger"
                    onclick="cantDelete('@category.Name')">
                        Smazat
                    </button>
                    }
                    else
                    {
                    <button type="button" class="btn btn-sm btn-danger"
                    onclick="confirmDelete(@category.Id, '@category.Name')">
                        Smazat
                    </button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
<div class="modal fade" id="cantDeleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Nelze smazat</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Kategorie <strong id="cantDeleteName"></strong> obsahuje produkty a nelze ji smazat. Nejdřív přeřaď produkty do jiné kategorie.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Zavřít</button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Smazat kategorii</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Opravdu chceš smazat kategorii <strong id="deleteCategoryName"></strong>?
                Tuto akci nelze vrátit zpět.
            </div>
            <div class="modal-footer">
                <form id="deleteForm" method="post">
                    <button type="submit" class="btn btn-danger">Smazat</button>
                </form>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Zrušit</button>
            </div>
        </div>
    </div>
    @section Scripts {
    <script>
        function cantDelete(name) {
            document.getElementById('cantDeleteName').textContent = name;
            new bootstrap.Modal(document.getElementById('cantDeleteModal')).show();
        }

        function confirmDelete(id, name) {
            document.getElementById('deleteCategoryName').textContent = name;
            document.getElementById('deleteForm').action = `/Categories/Index`;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
    }
</div>