@page "{id:int}"
@model WarehouseSystem.Pages.Categories.DeleteModel
@{
    ViewData["Title"] = "Smazat kategorii";
}

<h2>Opravdu chceš smazat tuto kategorii?</h2>

<div class="card" style="max-width: 400px;">
    <div class="card-body">
        <p><strong>Název:</strong> @Model.Category.Name</p>
        <p><strong>Popis:</strong> @Model.Category.Description</p>
        <p><strong>Počet produktů:</strong> @Model.Category.Products.Count</p>
    </div>
</div>

@if (Model.Category.Products.Count > 0)
{
    <div class="alert alert-warning mt-3">
        Tato kategorie obsahuje produkty. Před smazáním přeřaď produkty do jiné kategorie.
    </div>
}
else
{
    <form method="post" class="mt-3">
        <button type="submit" class="btn btn-danger">Ano, smazat</button>
        <a href="/Categories" class="btn btn-secondary">Zpět</a>
    </form>
}