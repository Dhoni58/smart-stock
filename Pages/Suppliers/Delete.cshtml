@page "{id:int}"
@model WarehouseSystem.Pages.Suppliers.DeleteModel
@{
    ViewData["Title"] = "Smazat dodavatele";
}

<h2>Opravdu chceš smazat tohoto dodavatele?</h2>

<div class="card" style="max-width: 400px;">
    <div class="card-body">
        <p><strong>IČO:</strong> @Model.Supplier.Ico</p>
        <p><strong>Název:</strong> @Model.Supplier.Name</p>
        <p><strong>Adresa:</strong> @Model.Supplier.Address</p>
        <p><strong>Kontaktní osoba:</strong> @(Model.Supplier.ContactPerson ?? "—")</p>
    </div>
</div>

<form method="post" class="mt-3">
    <button type="submit" class="btn btn-danger">Ano, smazat</button>
    <a href="/Suppliers" class="btn btn-secondary">Zpět</a>
</form>