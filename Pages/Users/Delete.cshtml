@page "{id:int}"
@model WarehouseSystem.Pages.Users.DeleteModel
@{
    ViewData["Title"] = "Smazat uživatele";
}

<h2>Opravdu chceš smazat tohoto uživatele?</h2>

<div class="card" style="max-width: 400px;">
    <div class="card-body">
        <p><strong>Jméno:</strong> @Model.User.Name</p>
        <p><strong>Role:</strong> @Model.User.Role</p>
    </div>
</div>

<form method="post" class="mt-3">
    <button type="submit" class="btn btn-danger">Ano, smazat</button>
    <a href="/Users" class="btn btn-secondary">Zpět</a>
</form>