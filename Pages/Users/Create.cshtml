@page
@model WarehouseSystem.Pages.Users.CreateModel
@{
    ViewData["Title"] = "Přidat uživatele";
}

<h2>Přidat uživatele</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <p class="mb-0">@error.ErrorMessage</p>
        }
    </div>
}

<form method="post" style="max-width: 500px;">
    <div class="mb-3">
        <label class="form-label">Jméno</label>
        <input asp-for="CurrentUser.Name" class="form-control" required />
    </div>
    <div class="mb-3">
        <label class="form-label">PIN (5 číslic)</label>
        <input asp-for="CurrentUser.Pin" class="form-control"
               type="password" maxlength="5" required />
    </div>
    <div class="mb-3">
        <label class="form-label">Role</label>
        <select asp-for="CurrentUser.Role" class="form-select">
            <option value="0">Skladník</option>
            <option value="1">Vedoucí</option>
        </select>
    </div>
    <button type="submit" class="btn btn-primary">Uložit</button>
    <a href="/Users" class="btn btn-secondary">Zpět</a>
</form>