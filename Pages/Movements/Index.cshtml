@page
@model WarehouseSystem.Pages.Movements.IndexModel
@{
    ViewData["Title"] = "Skladové pohyby";
}

<h2>Skladové pohyby</h2>

<div class="d-flex justify-content-between align-items-center mb-3">
    <a href="/Movements/Create" class="btn btn-primary">+ Přidat pohyb</a>
    <div class="d-flex gap-2">
        <a href="/api/export/movements/excel" class="btn btn-outline-success btn-sm" title="Export do Excelu">
            <img src="https://img.icons8.com/color/24/microsoft-excel-2019.png" />
        </a>
        <a href="/api/export/movements/pdf" class="btn btn-outline-danger btn-sm" title="Export do PDF">
            <img src="https://img.icons8.com/color/24/pdf.png" />
        </a>
    </div>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Datum</th>
            <th>Produkt</th>
            <th>Typ</th>
            <th>Množství</th>
            <th>Dodavatel</th>
            <th>Vytvořil</th>
            <th>Poznámka</th>
            <th>Faktura</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var movement in Model.Movements)
        {
            <tr>
                <td>@movement.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@movement.Product?.Name</td>
                <td>
                    @if (movement.Type == WarehouseSystem.Models.MovementType.Receipt)
                    {
                        <span class="badge bg-success">Příjem</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Výdej</span>
                    }
                </td>
                <td>@movement.Quantity ks</td>
                <td>@(movement.Supplier?.Name ?? "-")</td>
                <td>@(movement.CreatedByUser?.Name ?? "-")</td>
                <td>@movement.Note</td>
                <td>@(movement.Invoice?.InvoiceNumber ?? "-")</td>
            </tr>
        }
    </tbody>
</table>