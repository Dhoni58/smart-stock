@page
@model WarehouseSystem.Pages.LoginModel
@{
    ViewData["Title"] = "Přihlášení";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Smart Stock — Přihlášení</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light min-vh-100 d-flex align-items-center">
    <div class="container">
        <div class="row justify-content-center mt-5">
            <div class="col-md-4">
                <div class="card shadow">
                    <div class="card-body p-4">
                        <h3 class="text-center mb-4">Smart Stock</h3>
                        <h6 class="text-center text-muted mb-4">Zadejte svůj PIN</h6>

                        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                        {
                            <div class="alert alert-danger">@Model.ErrorMessage</div>
                        }

                        <form method="post">
                            <div class="mb-3">
                                <input asp-for="Pin"
                                       class="form-control form-control-lg text-center"
                                       type="password"
                                       maxlength="5"
                                       placeholder="_ _ _ _ _"
                                       autofocus
                                       autocomplete="off" />
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Přihlásit</button>
                        </form>    
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const input = document.querySelector('input[name="Pin"]');
        document.querySelectorAll('.pin-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const val = btn.dataset.value;
                if (val === '⌫')
                    input.value = input.value.slice(0, -1);
                else if (input.value.length < 5)
                    input.value += val;
            });
        });
    </script>
</body>
</html>