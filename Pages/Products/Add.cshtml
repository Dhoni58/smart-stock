@page
@model WarehouseSystem.Pages.Products.AddModel
@{
    ViewData["Title"] = "Přidat produkt";
}

<h2>Přidat produkt</h2>

<form method="post" style="max-width: 500px;">
    <div class="mb-3">
        <label class="form-label">Název</label>
        <input asp-for="Product.Name" class="form-control" required />
    </div>
    <div class="mb-3">
        <label class="form-label">Popis</label>
        <input asp-for="Product.Description" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Kategorie</label>
        <select asp-for="Product.CategoryId"
                asp-items="Model.CategoryList"
                class="form-select">
            <option value="">-- Bez kategorie --</option>
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label">Nákupní Cena</label>
        <input asp-for="Product.PurchasePrice" class="form-control" type="number" step="0.01" required />
    </div>
    <div class="mb-3">
        <label class="form-label">Prodejní Cena</label>
        <input asp-for="Product.SellingPrice" class="form-control" type="number" step="0.01" required />
    </div>
    <div class="mb-3">
        <label class="form-label">Minimální zásoba</label>
        <input asp-for="Product.MinimumInv" class="form-control" type="number" required />
    </div>
    <button type="submit" class="btn btn-primary">Uložit</button>
    <a href="/Products" class="btn btn-secondary">Zpět</a>
</form>