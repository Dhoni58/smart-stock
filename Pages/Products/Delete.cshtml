@page "{id:int}"
@model WarehouseSystem.Pages.Products.DeleteModel
@{
    ViewData["Title"] = "Smazat Produkt";
}
<h2>Opravdu chceš smazat tento produkt?</h2>

<div class="card" style="max-width: 400px;">
    <div class="card-body">
        <p><strong>Název:</strong> @Model.Product.Name</p>
        <p><strong>Cena:</strong> @Model.Product.Price.ToString("C")</p>
        <p><strong>Na skladě:</strong> @Model.Product.WarehouseInv ks</p>
    </div>
</div>

<form method="post" class="mt-3">
    <button type="submit" class="btn btn-danger">Ano, smazat</button>
    <a href="/Products" class="btn btn-secondary">Zpět</a>
</form>